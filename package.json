{
  "name": "grail",
  "displayName": "Grail (tail & grep)",
  "description": "Grail — read-only tail -f viewer with live follow, inline grep-style filtering, and safe log wipe.",
  "version": "0.1.0",
  "publisher": "joshuacarter",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:tailGrepViewer.open",
    "onCustomEditor:tailGrepViewer.view"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tailGrepViewer.open",
        "title": "Grail: Open File",
        "category": "Grail",
        "icon": "$(eye)"
      }
    ],
    "customEditors": [
      {
        "viewType": "tailGrepViewer.view",
        "displayName": "Grail (tail & grep)",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tailGrepViewer.open",
          "when": "!explorerResourceIsFolder",
          "group": "navigation@100"
        }
      ],
      "editor/title/context": [
        {
          "command": "tailGrepViewer.open",
          "group": "navigation@100"
        }
      ],
      "editor/context": [
        {
          "command": "tailGrepViewer.open",
          "group": "navigation@100"
        }
      ],
      "commandPalette": [
        {
          "command": "tailGrepViewer.open"
        }
      ]
    }
  }
}
