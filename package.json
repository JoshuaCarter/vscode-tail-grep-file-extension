{
  "name": "grail",
  "displayName": "Grail",
  "description": "Grail — read-only tail -f viewer with live follow, inline grep-style filtering, and safe log wipe.",
  "version": "1.0.0",
  "publisher": "joshuacarter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoshuaCarter/vscode-grail-extension"
  },
  "bugs": {
    "url": "https://github.com/JoshuaCarter/vscode-grail-extension/issues"
  },
  "homepage": "https://github.com/JoshuaCarter/vscode-grail-extension#readme",
  "keywords": ["log", "tail", "grep", "viewer", "grail"],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:tailGrepViewer.open",
    "onCommand:tailGrepViewer.openInTextEditor",
    "onCustomEditor:tailGrepViewer.view"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tailGrepViewer.open",
        "title": "Grail: Open File",
        "category": "Grail",
        "icon": "media/icon.png"
      },
      {
        "command": "tailGrepViewer.openInTextEditor",
        "title": "Grail: Open in Text Editor",
        "category": "Grail"
      }
    ],
    "customEditors": [
      {
        "viewType": "tailGrepViewer.view",
        "displayName": "Grail",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tailGrepViewer.open",
          "when": "!explorerResourceIsFolder",
          "group": "navigation@100"
        },
        {
          "command": "tailGrepViewer.openInTextEditor",
          "when": "!explorerResourceIsFolder",
          "group": "navigation@101"
        }
      ],
      "editor/title/context": [
        {
          "command": "tailGrepViewer.open",
          "group": "navigation@100"
        },
        {
          "command": "tailGrepViewer.openInTextEditor",
          "group": "navigation@101"
        }
      ],
      "editor/context": [
        {
          "command": "tailGrepViewer.open",
          "group": "navigation@100"
        },
        {
          "command": "tailGrepViewer.openInTextEditor",
          "group": "navigation@101"
        }
      ],
      "commandPalette": [
        {
          "command": "tailGrepViewer.open"
        },
        {
          "command": "tailGrepViewer.openInTextEditor"
        }
      ]
    }
  }
}
